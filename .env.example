# =============================================================================
# X-8G2T environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and replace every <CHANGE_ME> value.
#   cp .env.example .env
# Generate strong secrets with:  openssl rand -base64 32
# `.env` is git-ignored and must never be committed.
# =============================================================================

# ---- PostgreSQL (metadata, alarms, users, agent memory) ----
POSTGRES_USER=iot_admin
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=iot_telemetry

# ---- EMQX MQTT broker ----
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=<CHANGE_ME>
EMQX_JWT_SECRET=<CHANGE_ME>

# ---- IoTDB ----
IOTDB_USER=root
IOTDB_PASSWORD=root

# ---- Agent Orchestrator / API security ----
AI_API_KEY=<CHANGE_ME>
JWT_SECRET=<CHANGE_ME>

# ---- Grafana ----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<CHANGE_ME>

# ---- Superset ----
SUPERSET_SECRET_KEY=<CHANGE_ME>
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=<CHANGE_ME>

# =============================================================================
# AI MODELS (GGUF files placed in the shared `models` docker volume)
# Download them once with: ./scripts/download-models.sh
# -----------------------------------------------------------------------------
# Text reasoning model used by every agent.
LLM_MODEL_FILE=Llama-3.2-3B-Instruct-Q4_K_M.gguf

# Vision-language model for the Camera/Vision agent (needs an mmproj file).
VLM_MODEL_FILE=SmolVLM2-2.2B-Instruct-Q4_K_M.gguf
VLM_MMPROJ_FILE=mmproj-SmolVLM2-2.2B-Instruct-f16.gguf

# Embedding model that powers RAG ingestion + retrieval (768-dim).
EMBED_MODEL_FILE=nomic-embed-text-v1.5.Q8_0.gguf
EMBED_DIM=768

# RAG tuning
RAG_COLLECTION=x8g2t_knowledge
RAG_TOP_K=5
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_EMBED_BATCH=32

# RAG knowledge domains (the SPC books are indexed under the 'spc' domain so the
# SPC agent can retrieve them with rag_search(domain='spc')).
KB_DOMAIN=ops
BOOKS_DOMAIN=spc

# Agent tuning
AGENT_MAX_STEPS=6
AGENT_TEMPERATURE=0.3

# Local SPC MCP server (Statistical Process Control tools)
SPC_MCP_URL=http://spc-mcp:8765/mcp
